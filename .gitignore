# .gitignore — Manga Downloader

# === Sensitive Data ===
cache/cookies.json
cache/history.db
cache/history.json
cache/favorites.json
cache/queue_state.json
cache/followed.json
cache/progress.json
cache/profile_stats.json
cache/*.db
cache/*.sqlite
*.db
*.sqlite

# === Browser Profiles ===
browser_profile/
**/browser_profile/

# === Downloaded Content ===
downloads/
downloads_*/
exports/
output/

# === Python ===
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg

# === IDEs / Editors ===
.vscode/
.idea/
*.swp
*.swo
*~

# === OS ===
.DS_Store
Thumbs.db
Desktop.ini

# === Logs ===
*.log

# === Temporary ===
*.tmp
*.temp
*.bak
*.cache

# === Backups ===
backup/

# === Feature Branches / Duplicates ===
manga_downloader_features/
release/
prv_edition/

# === Test Artifacts ===
test_*/
_test_*/

# === Virtual Environment ===
venv/
.venv/
env/

# === Environment ===
.env
.env.local
